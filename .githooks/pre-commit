#!/bin/sh
set -e

# Auto-fix lint + format the whole tree, then re-stage the fixes onto the files
# already staged for this commit (so unrelated dirty files aren't pulled in).
# Deleted paths are excluded (--diff-filter=d) — they have nothing to reformat,
# and passing a removed path to `git add` errors. Lint errors that can't be
# auto-fixed still abort (set -e).
bun run lint:fix
bun run format
files=$(git diff --cached --name-only --diff-filter=d)
[ -n "$files" ] && git add -- $files
# The && above returns 1 when nothing is staged (empty-diff commits, e.g.
# merges) — don't let that abort the commit.
exit 0
